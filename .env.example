# Copy this file to `.env` in the **repository root** (same folder as this
# `.env.example`), then fill in values. Never commit `.env`.
#
# The hackathon app loads that file on startup (`load_dotenv` from `main.py`).

# ---------------------------------------------------------------------------
# LLM provider — data_ingestion and evidence_aggregation
# ---------------------------------------------------------------------------

# Which provider to use.  Supported: stub (default) | openai | anthropic
# BILLION_LLM_PROVIDER=stub
#
# With stub, ingesting the exact "Load scenario 1" (Story/1) or "Load scenario 2" (Story/2)
# file sets uses story-aligned gold evidence (see Story/1/Story1.md, Story/2/Story2.md) so
# the pipeline works offline. With openai/anthropic, real vision runs on the uploaded images.

# API key for the selected provider.
# BILLION_LLM_API_KEY=

# Model name.  Defaults when empty:
#   openai    → gpt-4o
#   anthropic → claude-3-5-sonnet-20241022
# BILLION_LLM_MODEL=

# OpenAI-compatible base URL (only used when BILLION_LLM_PROVIDER=openai).
# Leave blank for the official OpenAI endpoint; override for OpenRouter,
# Together AI, a local Ollama instance, etc.
# BILLION_LLM_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# bunq / Open Banking
# ---------------------------------------------------------------------------

# BUNQ_API_KEY=
# BUNQ_ENV=sandbox

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------

# APP_BASE_URL=http://localhost:8080
